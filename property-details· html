<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Property Details | Baribaba</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',sans-serif}
    body{background:#f6f7f9;color:#222}

    header{background:#fff;padding:16px 60px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 2px 10px rgba(0,0,0,.06)}
    header img{height:40px}
    nav a{margin-left:25px;text-decoration:none;color:#222;font-weight:500}
    nav a:hover{color:#d81f26}

    .container{max-width:1100px;margin:auto;padding:60px}

    .property{display:grid;grid-template-columns:1.3fr 1fr;gap:40px}

    .property img{width:100%;border-radius:18px}

    .details{background:#fff;padding:35px;border-radius:18px;box-shadow:0 10px 30px rgba(0,0,0,.08)}
    .details h1{margin-bottom:10px}
    .price{color:#d81f26;font-size:24px;font-weight:700;margin-bottom:15px}
    .tag{display:inline-block;background:#f1f1f1;padding:6px 12px;border-radius:20px;margin-bottom:15px;font-size:14px}

    .info p{margin-bottom:10px;color:#555}

    .actions{margin-top:25px}
    .actions a{display:block;text-align:center;background:#25d366;color:#fff;text-decoration:none;padding:14px;border-radius:10px;font-weight:600}
    .actions a:hover{opacity:.9}

    footer{background:#111;color:#aaa;text-align:center;padding:30px;margin-top:80px}

    @media(max-width:900px){
      .property{grid-template-columns:1fr}
      header,.container{padding:30px}
    }
  </style>
</head>
<body>

<header>
  <img src="assets/images/logo.png" alt="Baribaba Logo" />
  <nav>
    <a href="index.html">Home</a>
    <a href="services.html">Services</a>
    <a href="management.html">Management</a>
    <a href="contact.html">Contact</a>
  </nav>
</header>

<div class="container">
  <div class="property">

    <img src="assets/images/property1.jpg" alt="Property Image">

    <div class="details">
      <span class="tag">2BHK • Semi Furnished</span>
      <h1>2BHK Semi Furnished Flat</h1>
      <p class="price">₹16,000 / month</p>

      <div class="info">
        <p><strong>Location:</strong> Kalabagan, Tollygunge, Kolkata 700053</p>
        <p><strong>Nearby:</strong> NSHM College</p>
        <p><strong>Property Type:</strong> Residential Flat</p>
        <p><strong>Availability:</strong> Immediately</p>
      </div>

      <div class="actions">
        <a href="https://wa.me/918240473982" target="_blank">Request Owner Number on WhatsApp</a>
      </div>
    </div>

  </div>
</div>

<footer>
